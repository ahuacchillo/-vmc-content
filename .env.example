# Instagram Graph API — cuenta Business/Creator vinculada a una Página de Facebook.
# Se obtienen en Meta for Developers (ver README).
IG_USER_ID=
IG_ACCESS_TOKEN=

# URL pública desde la que Instagram descarga las imágenes.
# DEBE ser accesible por internet (Instagram no puede leer localhost).
#   - local: usa un túnel -> ngrok http 3000  (pega aquí la URL https que te dé)
#   - prod:  tu dominio, p.ej. https://publisher.subastop.com
PUBLIC_BASE_URL=
